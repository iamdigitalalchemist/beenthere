# Optional: absolute app URL for QR codes and share links in production.
NEXT_PUBLIC_APP_URL=

# Optional: secret for signed gallery PIN access cookies.
PIN_ACCESS_SECRET=

# Comma-separated emails allowed to use the host dashboard.
# These accounts will also bypass the paywall once billing ships.
HOST_EMAIL_ALLOWLIST=iamdigitalalchemist@gmail.com

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
POSTGRES_URL=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

TRIGGER_SECRET_KEY=

# Development-only: stores uploads under public/local-media when R2 is absent.
LOCAL_UPLOADS_ENABLED=false
